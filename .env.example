# SQLite file path used by Prisma
DATABASE_URL="file:./dev.db"

# HTTP port for the API
PORT=3000

# LLM provider: "mock" (default, no key required) or "openai"
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Worker tuning
WORKER_CONCURRENCY=2
LLM_TIMEOUT_MS=10000

# Sweeper (rescues jobs stuck in ANALYZING after a worker crash).
# Should be comfortably larger than LLM_TIMEOUT_MS to avoid double-processing
# legitimate slow runs.
SWEEPER_INTERVAL_MS=30000
SWEEPER_STALE_AFTER_MS=120000
